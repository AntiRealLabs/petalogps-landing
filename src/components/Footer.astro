---
import PetaloIsotipo from "./PetaloIsotipo.astro";
import PetaloWordmark from "./PetaloWordmark.astro";
---

<footer class="border-t border-horizonte/16 bg-white/70 py-10">
  <div class="container-petalo flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
    <div>
      <a href="#hero" class="inline-flex items-center gap-2" aria-label="Volver al inicio">
        <PetaloIsotipo idPrefix="footer-logo" class="h-9 w-10" title="Isotipo PetAlo" />
        <PetaloWordmark tm class="text-2xl" />
      </a>
      <p class="mt-3 text-sm text-niebla">© 2026 Anti-Real Labs S.A.S. · Hecho en Medellín, Colombia 🇨🇴</p>
      <p class="mt-1 text-xs text-niebla/80">PetAlo™ es marca de Anti-Real Labs S.A.S. · Solicitud SIC No. SD2026/0043790</p>
    </div>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm font-bold text-tinta-suave">
      <a class="hover:text-horizonte-oscuro" href="mailto:hola@petalogps.com">hola@petalogps.com</a>
      <a class="hover:text-horizonte-oscuro" href="#">Privacidad</a>
      <a class="hover:text-horizonte-oscuro" href="#">Términos</a>
      <a class="hover:text-horizonte-oscuro" href="#" aria-label="Instagram de PetAlo">Instagram</a>
      <a class="hover:text-horizonte-oscuro" href="#" aria-label="TikTok de PetAlo">TikTok</a>
      <a class="hover:text-horizonte-oscuro" href="#" aria-label="X de PetAlo">X</a>
    </div>
  </div>
</footer>
