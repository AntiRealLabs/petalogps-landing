---
import { Clock, MapPinOff, SearchX } from "@lucide/astro";

const problems = [
  {
    icon: Clock,
    title: "Ansiedad constante",
    text: "El 25% de mascotas se escapan al menos una vez en la vida. Vivimos con miedo de que pase.",
  },
  {
    icon: MapPinOff,
    title: "Tracking imperfecto",
    text: "Los GPS tradicionales son grandes, agresivos, mandan alertas estridentes y duran horas, no días.",
  },
  {
    icon: SearchX,
    title: "Sin contexto",
    text: "Solo te dicen dónde está. No cómo está, qué hace o si necesita algo.",
  },
];
---

<section id="problema" class="section section--soft">
  <div class="container-petalo">
    <div class="section-header" data-reveal>
      <p class="section-kicker">El problema</p>
      <h2 class="section-title">Cuando tu mascota desaparece, el tiempo se detiene</h2>
      <p class="section-copy">
        PetAlo nace de una preocupación real, pero responde con calma: menos ruido, más contexto y decisiones más humanas.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {
        problems.map(({ icon: Icon, title, text }) => (
          <article class="soft-card p-6" data-reveal>
            <div class="icon-badge mb-5">
              <Icon aria-hidden="true" />
            </div>
            <h3 class="text-2xl">{title}</h3>
            <p class="mt-3">{text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
